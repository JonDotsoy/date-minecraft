---
import { HomePage } from "../componentes/home-page";
import { getImage } from "astro:assets";
import coverImage from "../componentes/cover.png";
import minecraftClockIcon from "../componentes/minecraft-clock-icon.png";

const cover = await getImage({ src: coverImage, width: 1200, height: 630 });
const coverUrl = Astro.url.origin + cover.src;

const appleTouchIcon = await getImage({ src: minecraftClockIcon, width: 180, height: 180, format: "png" });
const favicon32 = await getImage({ src: minecraftClockIcon, width: 32, height: 32, format: "png" });
const favicon16 = await getImage({ src: minecraftClockIcon, width: 16, height: 16, format: "png" });
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon.src} />
		<link rel="icon" type="image/png" sizes="32x32" href={favicon32.src} />
		<link rel="icon" type="image/png" sizes="16x16" href={favicon16.src} />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Minecraft Date Clock</title>
		<meta name="description" content="Convert real-world time to Minecraft ticks and dates. Live Minecraft clock, tick converter, and JavaScript library." />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Minecraft Date Clock" />
		<meta property="og:description" content="Convert real-world time to Minecraft ticks and dates. Live Minecraft clock, tick converter, and JavaScript library." />
		<meta property="og:site_name" content="Minecraft Date Clock" />
		<meta property="og:image" content={coverUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Minecraft Date Clock" />
		<meta name="twitter:description" content="Convert real-world time to Minecraft ticks and dates. Live Minecraft clock, tick converter, and JavaScript library." />
		<meta name="twitter:image" content={coverUrl} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet" />
	</head>
	<body>
		<HomePage client:load />
	</body>
</html>

<style is:global>
	*, *::before, *::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: 'Press Start 2P', monospace;
		image-rendering: pixelated;
		min-height: 100vh;
		display: flex;
		justify-content: center;
		align-items: flex-start;
		padding: 24px 16px;
		/* Dirt-like pixelated background */
		background-color: #120a00;
		background-image:
			linear-gradient(45deg, rgba(60,30,0,0.4) 25%, transparent 25%),
			linear-gradient(-45deg, rgba(40,20,0,0.4) 25%, transparent 25%),
			linear-gradient(45deg, transparent 75%, rgba(80,40,0,0.3) 75%),
			linear-gradient(-45deg, transparent 75%, rgba(30,15,0,0.3) 75%);
		background-size: 8px 8px;
		background-position: 0 0, 0 4px, 4px -4px, -4px 0px;
	}

	input[type="number"],
	input[type="text"],
	input[type="range"] {
		font-family: 'Press Start 2P', monospace;
	}
</style>
