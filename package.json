{
  "name": "@jondotsoy/date-minecraft",
  "version": "0.1.0",
  "description": "A library to work with Minecraft dates and ticks",
  "module": "lib/date-minecraft.js",
  "main": "lib/date-minecraft.js",
  "types": "lib/date-minecraft.d.ts",
  "exports": {
    ".": {
      "import": "./lib/date-minecraft.js",
      "types": "./lib/date-minecraft.d.ts"
    }
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "scripts": {
    "prepack": "rm -rf lib && tsc -p tsconfig.esm.json"
  },
  "author": "Jonathan Delgado <hi@jon.soy> (https://jon.soy)",
  "keywords": ["minecraft"],
  "license": "MIT",
  "private": false,
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "temporal-polyfill": "0.3.2"
  }
}
